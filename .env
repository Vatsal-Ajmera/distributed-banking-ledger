# ─────────────────────────────────────────────────────────────────────────────
# Local development environment variables
# Copy this file to .env.local and override values for your machine.
# Never commit secrets — this file contains safe defaults only.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=customer_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Kafka (KRaft — no Zookeeper)
KAFKA_PORT=9092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# Stable cluster ID for local dev — regenerate with: kafka-storage.sh random-uuid
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# customer-service
CUSTOMER_SERVICE_PORT=8081
